---
import { getTranslations, type Language } from '../i18n/utils'

interface Props {
  lang?: Language;
}

const { lang = 'en' } = Astro.props;
const t = getTranslations(lang);

const currentPath = Astro.url.pathname;
const isHome = currentPath === '/' || currentPath === '/index.astro';
const isProjects = currentPath.includes('/projects');
const isAbout = currentPath.includes('/about') || currentPath.includes('/skills');
const isContact = currentPath.includes('/contact');
---

<header class="w-full flex flex-col md:flex-row items-center bg-surface text-text-muted border-b border-border text-sm z-50">
  <!-- Brand / Sidebar Toggle Area -->
  <div class="w-full md:w-64 px-6 py-3 border-b md:border-b-0 md:border-r border-border flex justify-between items-center shrink-0">
    <a href={`/?lang=${lang}`} class="hover:text-text transition-colors font-medium">
      juan-manuel-machado
    </a>
    <button id="menu-toggle" class="md:hidden text-text-muted">
      <span class="material-symbols-outlined">menu</span>
    </button>
  </div>

  <!-- Desktop Tabs -->
  <nav class="hidden md:flex flex-grow items-stretch overflow-x-auto no-scrollbar h-full">
    <a 
      href={`/?lang=${lang}`} 
      class={`px-6 py-3 border-r border-border transition-colors flex items-center gap-4 relative group ${isHome ? 'text-text bg-surface-elevated after:absolute after:bottom-0 after:left-0 after:w-full after:h-[2px] after:bg-primary' : 'hover:text-text hover:bg-surface-elevated/50'}`}
    >
      <span>{t.nav.home}</span>
      <span class="material-symbols-outlined text-[14px] opacity-0 group-hover:opacity-100 transition-opacity">close</span>
    </a>
    <a 
      href={`/about?lang=${lang}`} 
      class={`px-6 py-3 border-r border-border transition-colors flex items-center gap-4 relative group ${isAbout ? 'text-text bg-surface-elevated after:absolute after:bottom-0 after:left-0 after:w-full after:h-[2px] after:bg-primary' : 'hover:text-text hover:bg-surface-elevated/50'}`}
    >
      <span>{t.nav.about}</span>
      <span class="material-symbols-outlined text-[14px] opacity-0 group-hover:opacity-100 transition-opacity">close</span>
    </a>
    <a 
      href={`/projects?lang=${lang}`} 
      class={`px-6 py-3 border-r border-border transition-colors flex items-center gap-4 relative group ${isProjects ? 'text-text bg-surface-elevated after:absolute after:bottom-0 after:left-0 after:w-full after:h-[2px] after:bg-primary' : 'hover:text-text hover:bg-surface-elevated/50'}`}
    >
      <span>{t.nav.projects}</span>
      <span class="material-symbols-outlined text-[14px] opacity-0 group-hover:opacity-100 transition-opacity">close</span>
    </a>
  </nav>

  <!-- Right side (Contact + Lang) -->
  <div class="hidden md:flex items-stretch h-full">
    <a 
      href={`/contact?lang=${lang}`} 
      class={`px-6 py-3 border-l border-border transition-colors flex items-center gap-4 relative group ${isContact ? 'text-text bg-surface-elevated after:absolute after:bottom-0 after:left-0 after:w-full after:h-[2px] after:bg-primary' : 'hover:text-text hover:bg-surface-elevated/50'}`}
    >
      <span>{t.nav.contact}</span>
      <span class="material-symbols-outlined text-[14px] opacity-0 group-hover:opacity-100 transition-opacity">close</span>
    </a>
    <!-- Language Select (Desktop) -->
    <div class="px-4 py-3 border-l border-border flex items-center justify-center bg-surface">
      <select
        id="language-select"
        class="bg-transparent text-text-muted focus:outline-none cursor-pointer hover:text-text transition-colors font-mono text-xs"
      >
        <option value="en" class="bg-surface" selected={lang === 'en'}>EN</option>
        <option value="es" class="bg-surface" selected={lang === 'es'}>ES</option>
      </select>
    </div>
  </div>

  <!-- Mobile Nav -->
  <nav id="mobile-nav" class="hidden w-full flex-col md:hidden bg-surface border-t border-border">
    <a href={`/?lang=${lang}`} class={`px-6 py-4 border-b border-border ${isHome ? 'text-text bg-surface-elevated' : 'text-text-muted'}`}>{t.nav.home}</a>
    <a href={`/about?lang=${lang}`} class={`px-6 py-4 border-b border-border ${isAbout ? 'text-text bg-surface-elevated' : 'text-text-muted'}`}>{t.nav.about}</a>
    <a href={`/projects?lang=${lang}`} class={`px-6 py-4 border-b border-border ${isProjects ? 'text-text bg-surface-elevated' : 'text-text-muted'}`}>{t.nav.projects}</a>
    <a href={`/contact?lang=${lang}`} class={`px-6 py-4 border-b border-border ${isContact ? 'text-text bg-surface-elevated' : 'text-text-muted'}`}>{t.nav.contact}</a>
    <div class="px-6 py-4 flex items-center justify-between">
      <span class="text-text-muted text-xs font-mono">{t.language.select}</span>
      <select
        id="language-select-mobile"
        class="bg-surface-elevated text-text px-2 py-1 rounded border border-border focus:outline-none text-xs"
      >
        <option value="en" selected={lang === 'en'}>EN</option>
        <option value="es" selected={lang === 'es'}>ES</option>
      </select>
    </div>
  </nav>
</header>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const select = document.getElementById('language-select') as HTMLSelectElement
    const selectMobile = document.getElementById('language-select-mobile') as HTMLSelectElement
    const menuToggle = document.getElementById('menu-toggle')
    const mobileNav = document.getElementById('mobile-nav')
    
    const handleLangChange = (e: Event) => {
      const newLang = (e.target as HTMLSelectElement).value
      const url = new URL(window.location.href)
      url.searchParams.set('lang', newLang)
      window.location.href = url.toString()
    }
    
    if (select) select.addEventListener('change', handleLangChange)
    if (selectMobile) selectMobile.addEventListener('change', handleLangChange)

    if (menuToggle && mobileNav) {
      menuToggle.addEventListener('click', () => {
        mobileNav.classList.toggle('hidden')
      })
    }
  })
</script>
