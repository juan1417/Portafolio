---
import { getTranslations, type Language } from "../i18n/utils";

const lang = (Astro.url.searchParams.get('lang') || 'en') as Language;
---

<footer class="w-full border-t border-border flex flex-row items-center bg-surface text-text-muted text-[12px] font-mono z-50 overflow-x-auto no-scrollbar">
  <!-- Left Side: Git Info -->
  <div class="flex items-center shrink-0">
    <div class="flex items-center gap-2 px-4 py-1 border-r border-border hover:text-text transition-colors cursor-pointer">
      <i class="fa-solid fa-code-branch"></i>
      <span>main*</span>
    </div>
    <div class="hidden md:flex items-center gap-2 px-4 py-1 border-r border-border hover:text-text transition-colors cursor-pointer">
      <i class="fa-solid fa-sync fa-spin-pulse"></i>
      <span>0</span>
      <i class="fa-solid fa-triangle-exclamation"></i>
      <span>0</span>
    </div>
  </div>

  <!-- Middle: Social Links (Desktop) -->
  <div class="hidden md:flex flex-grow items-center">
    <span class="px-4 py-1">find me in:</span>
    <a href="https://www.linkedin.com/in/juanmachado1234" target="_blank" class="px-3 py-1 border-l border-border hover:text-text transition-colors flex items-center justify-center h-full">
      <i class="fa-brands fa-linkedin"></i>
    </a>
  </div>

  <!-- Right Side: Editor Info -->
  <div class="flex items-center ml-auto shrink-0">
    <a href="https://github.com/juan1417" target="_blank" class="hidden md:flex items-center gap-2 px-4 py-1 border-l border-border hover:text-text transition-colors">
      <span>@juan1417</span>
      <i class="fa-brands fa-github text-sm"></i>
    </a>
    <div class="hidden lg:flex items-center gap-4 px-4 py-1 border-l border-border">
      <span>Ln 1, Col 1</span>
      <span>Spaces: 2</span>
      <span>UTF-8</span>
      <div class="flex items-center gap-1 hover:text-text transition-colors cursor-pointer">
        <i class="fa-solid fa-check-double text-success"></i>
        <span>Prettier</span>
      </div>
    </div>
    <div class="flex items-center gap-2 px-4 py-1 border-l border-border bg-indigo/10 text-indigo hover:bg-indigo hover:text-white transition-all cursor-pointer">
      <i class="fa-solid fa-bell"></i>
    </div>
  </div>
</footer>