---
import { getTranslations, type Language } from '../i18n/utils';

interface Props {
  lang?: Language;
}

const { lang = 'en' } = Astro.props;
---

<div class="relative w-full max-w-2xl mx-auto p-4 z-10 hidden xl:block">
  <div class="bg-surface/40 border border-border rounded-lg overflow-hidden flex flex-row h-[475px] relative backdrop-blur-sm p-8 gap-8 shadow-inner">
    
    <!-- Game Canvas Area -->
    <div class="relative w-[240px] h-full bg-background/60 flex items-center justify-center overflow-hidden border border-border rounded-lg shadow-[inset_0_0_20px_rgba(0,0,0,0.8)]">
      <canvas id="snake-canvas" class="max-w-full max-h-full"></canvas>
      
      <!-- Start Game Overlay -->
      <div id="game-overlay" class="absolute inset-0 bg-surface/20 backdrop-blur-[2px] flex flex-col items-center justify-end pb-12 z-10 transition-all duration-300">
        <button id="start-game" class="bg-primary text-background font-bold px-6 py-3 rounded-lg hover:bg-primary/90 transition-all text-xs tracking-wider shadow-lg active:scale-95">
          start-game
        </button>
      </div>

      <!-- Game Over Overlay -->
      <div id="game-over-overlay" class="absolute inset-0 bg-surface/80 backdrop-blur-sm flex flex-col items-center justify-center z-20 hidden">
        <div class="bg-surface border border-border p-8 rounded-lg text-center shadow-2xl">
          <h2 class="text-secondary text-2xl font-bold mb-2 font-mono">GAME OVER!</h2>
          <p class="text-text-muted text-sm mb-6 font-mono">// better luck next time</p>
          <button id="play-again" class="text-text-muted hover:text-text font-mono transition-colors text-sm underline decoration-secondary underline-offset-4">
            play-again
          </button>
        </div>
      </div>

      <!-- Win Overlay -->
      <div id="win-overlay" class="absolute inset-0 bg-surface/80 backdrop-blur-sm flex flex-col items-center justify-center z-20 hidden">
        <div class="bg-surface border border-border p-8 rounded-lg text-center shadow-2xl">
          <h2 class="text-secondary text-2xl font-bold mb-2 font-mono">WELL DONE!</h2>
          <p class="text-text-muted text-sm mb-6 font-mono">// you cleared the game</p>
          <button id="win-play-again" class="text-text-muted hover:text-text font-mono transition-colors text-sm underline decoration-secondary underline-offset-4">
            play-again
          </button>
        </div>
      </div>
    </div>

    <!-- Game UI Area -->
    <div class="flex-grow flex flex-col justify-between text-text-muted bg-transparent">
      <div class="space-y-8">
        <!-- Controls Guide -->
        <div class="bg-surface-elevated/40 p-4 rounded-lg border border-border/50">
          <div class="font-mono text-[12px] mb-4">
            <p class="text-text-muted">// use keyboard</p>
            <p class="text-text-muted">// arrows to play</p>
          </div>
          
          <div class="grid grid-cols-3 gap-1 w-24 mx-auto">
            <div class="col-start-2 border border-border/50 p-2 rounded bg-background/40 text-text flex items-center justify-center h-8">
              <i class="fa-solid fa-caret-up text-xs"></i>
            </div>
            <div class="col-start-1 border border-border/50 p-2 rounded bg-background/40 text-text flex items-center justify-center h-8">
              <i class="fa-solid fa-caret-left text-xs"></i>
            </div>
            <div class="col-start-2 border border-border/50 p-2 rounded bg-background/40 text-text flex items-center justify-center h-8">
              <i class="fa-solid fa-caret-down text-xs"></i>
            </div>
            <div class="col-start-3 border border-border/50 p-2 rounded bg-background/40 text-text flex items-center justify-center h-8">
              <i class="fa-solid fa-caret-right text-xs"></i>
            </div>
          </div>
        </div>

        <!-- Food Counter -->
        <div class="space-y-4">
          <div class="text-text-muted font-mono text-[12px]">
            <p>// food left</p>
          </div>
          <div id="food-dots" class="grid grid-cols-5 gap-4">
            <!-- Dots generated by JS -->
          </div>
        </div>
      </div>

      <!-- Skip Button -->
      <div class="mt-auto flex justify-end">
        <button id="skip-game" class="border border-border/50 px-4 py-2 rounded-lg hover:bg-surface-elevated transition-colors text-[12px] font-mono hover:text-text">
          skip
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const canvas = document.getElementById('snake-canvas') as HTMLCanvasElement;
    const ctx = canvas.getContext('2d')!;
    const overlay = document.getElementById('game-overlay')!;
    const winOverlay = document.getElementById('win-overlay')!;
    const btnWinAgain = document.getElementById('win-play-again')!;

    // Make buttons read to avoid unused warnings
    if (!btnStart || !btnAgain || !btnSkip || !btnWinAgain) return;

    // Game Configuration
    const GRID_SIZE = 10;
    const MAX_FOOD = 10;
    let canvasWidth: number, canvasHeight: number;
    
    let snake: {x: number, y: number}[];
    let food: {x: number, y: number} | null = null;
    let direction = {x: 0, y: 0};
    let nextDirection = {x: 0, y: 0};
    let gameLoop: number | null = null;
    let foodEaten = 0;
    let gameStatus: 'idle' | 'playing' | 'gameOver' = 'idle';

    function resizeCanvas() {
      const parent = canvas.parentElement;
      if (!parent) return;
      canvasWidth = Math.floor(parent.clientWidth / GRID_SIZE) * GRID_SIZE;
      canvasHeight = Math.floor(parent.clientHeight / GRID_SIZE) * GRID_SIZE;
      canvas.width = canvasWidth;
      canvas.height = canvasHeight;
    }

    window.addEventListener('resize', resizeCanvas);
    resizeCanvas();

    function initGame() {
      snake = [
        {x: Math.floor(canvasWidth / 2 / GRID_SIZE) * GRID_SIZE, y: Math.floor(canvasHeight / 2 / GRID_SIZE) * GRID_SIZE},
        {x: Math.floor(canvasWidth / 2 / GRID_SIZE) * GRID_SIZE, y: Math.floor(canvasHeight / 2 / GRID_SIZE) * GRID_SIZE + GRID_SIZE},
        {x: Math.floor(canvasWidth / 2 / GRID_SIZE) * GRID_SIZE, y: Math.floor(canvasHeight / 2 / GRID_SIZE) * GRID_SIZE + (GRID_SIZE * 2)},
      ];
      direction = {x: 0, y: -1};
      nextDirection = {x: 0, y: -1};
      foodEaten = 0;
      gameStatus = 'playing';
      spawnFood();
      updateFoodDots();
      
      overlay.classList.add('hidden');
      gameOverOverlay.classList.add('hidden');
      winOverlay.classList.add('hidden');
      
      if (gameLoop) clearInterval(gameLoop);
      gameLoop = window.setInterval(update, 100);
    }

    function spawnFood() {
      food = {
        x: Math.floor(Math.random() * (canvasWidth / GRID_SIZE)) * GRID_SIZE,
        y: Math.floor(Math.random() * (canvasHeight / GRID_SIZE)) * GRID_SIZE,
      };
      // Avoid spawning food on snake
      if (snake.some(segment => segment.x === food?.x && segment.y === food?.y)) {
        spawnFood();
      }
    }

    function updateFoodDots() {
      foodDotsContainer.innerHTML = '';
      for (let i = 0; i < MAX_FOOD; i++) {
        const dot = document.createElement('div');
        const isEaten = i < foodEaten;
        dot.className = `w-2 h-2 rounded-full transition-all duration-300 ${isEaten ? 'bg-secondary shadow-[0_0_8px_#43D9AD]' : 'bg-surface-elevated border border-border'}`;
        foodDotsContainer.appendChild(dot);
      }
    }

    function update() {
      direction = nextDirection;
      const head = {x: snake[0].x + direction.x * GRID_SIZE, y: snake[0].y + direction.y * GRID_SIZE};

      // Wall Collision
      if (head.x < 0 || head.x >= canvasWidth || head.y < 0 || head.y >= canvasHeight) {
        endGame();
        return;
      }

      // Self Collision
      if (snake.some(segment => segment.x === head.x && segment.y === head.y)) {
        endGame();
        return;
      }

      snake.unshift(head);

      // Food Collision
      if (food && head.x === food.x && head.y === food.y) {
        foodEaten++;
        updateFoodDots();
        if (foodEaten >= MAX_FOOD) {
          endGame(true);
          return;
        }
        spawnFood();
      } else {
        snake.pop();
      }

      draw();
    }

    function draw() {
      ctx.clearRect(0, 0, canvasWidth, canvasHeight);

      // Draw Food
      if (food) {
        ctx.fillStyle = '#43D9AD';
        ctx.shadowBlur = 10;
        ctx.shadowColor = '#43D9AD';
        ctx.beginPath();
        ctx.arc(food.x + GRID_SIZE / 2, food.y + GRID_SIZE / 2, GRID_SIZE / 2.5, 0, Math.PI * 2);
        ctx.fill();
        ctx.shadowBlur = 0;
      }

      // Draw Snake
      snake.forEach((segment, index) => {
        ctx.fillStyle = index === 0 ? '#43D9AD' : '#43D9AD99';
        ctx.fillRect(segment.x + 0.5, segment.y + 0.5, GRID_SIZE - 1, GRID_SIZE - 1);
      });
    }

    function endGame(win = false) {
      gameStatus = 'gameOver';
      if (gameLoop) clearInterval(gameLoop);
      
      if (win) {
        winOverlay.classList.remove('hidden');
      } else {
        gameOverOverlay.classList.remove('hidden');
      }
    }

    window.addEventListener('keydown', (e) => {
      if (gameStatus !== 'playing') return;
      
      switch (e.key) {
        case 'ArrowUp': if (direction.y === 0) nextDirection = {x: 0, y: -1}; break;
        case 'ArrowDown': if (direction.y === 0) nextDirection = {x: 0, y: 1}; break;
        case 'ArrowLeft': if (direction.x === 0) nextDirection = {x: -1, y: 0}; break;
        case 'ArrowRight': if (direction.x === 0) nextDirection = {x: 1, y: 0}; break;
      }
    });

    btnStart.addEventListener('click', initGame);
    btnAgain.addEventListener('click', initGame);
    btnWinAgain.addEventListener('click', initGame);
    btnSkip.addEventListener('click', () => {
      overlay.classList.add('hidden');
      gameOverOverlay.classList.add('hidden');
      winOverlay.classList.add('hidden');
    });
  })
</script>
