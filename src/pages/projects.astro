---
import Base from "../layout/base.astro";
import { getTranslations, type Language } from "../i18n/utils";
import { getRepos } from "../utils/githubRepos";

const lang = (Astro.url.searchParams.get("lang") || "en") as Language;
const t = getTranslations(lang);

// Fetch repositories using the cached helper
const { repos, fetchError } = await getRepos();

const langIcons: Record<string, string> = {
  "JavaScript":  "devicon-javascript-plain",
  "TypeScript":  "devicon-typescript-plain",
  "Python":      "devicon-python-plain",
  "PHP":         "devicon-php-plain",
  "Kotlin":      "devicon-kotlin-plain",
  "Java":        "devicon-java-plain",
  "C#":          "devicon-csharp-plain",
  "Go":          "devicon-go-plain",
  "HTML":        "devicon-html5-plain",
  "CSS":         "devicon-css3-plain",
};

const allTechs: string[] = Array.from(
  new Set<string>(repos.flatMap(r => [...(r.languages || []), ...(r.topics || [])]))
).filter(
  (tech) => langIcons[tech] || ["React", "Vue", "Angular", "Laravel", "Node", "Tailwind"].includes(tech)
).slice(0, 8);
---

<Base lang={lang}>
  <main class="flex-grow flex overflow-hidden h-full">
    <!-- Left Sidebar (Filters) -->
    <aside class="w-64 border-r border-border hidden md:flex flex-col bg-surface shrink-0">
      <div class="px-4 py-2 text-text-muted text-[11px] uppercase tracking-wider font-bold flex items-center justify-between border-b border-border">
        <span>projects</span>
        <i class="fa-solid fa-filter text-[10px]"></i>
      </div>
      
      <div class="py-4">
        <button class="folder-toggle w-full flex items-center gap-2 px-4 py-2 text-text text-sm hover:bg-surface-elevated transition-colors group font-mono" data-target="tech-filters-list">
          <i class="fa-solid fa-caret-down text-[10px] transition-transform duration-200"></i>
          technologies
        </button>
        <div class="pl-4 pb-4 space-y-3 pt-2" id="tech-filters-list">
          {allTechs.map(tech => (
            <label class="flex items-center gap-3 cursor-pointer group px-4">
              <input type="checkbox" class="tech-filter hidden" value={tech.toLowerCase()} checked />
              <div class="w-4 h-4 border border-text-muted rounded-sm flex items-center justify-center group-hover:border-text transition-all bg-transparent relative">
                  <i class="fa-solid fa-check text-[10px] text-text-muted hidden check-mark"></i>
              </div>
              <div class="flex items-center gap-2 text-text-muted text-sm group-hover:text-text transition-colors font-mono">
                <i class={`${langIcons[tech] || "fa-solid fa-code"} text-sm opacity-70 group-hover:opacity-100`}></i>
                {tech}
              </div>
            </label>
          ))}
        </div>
      </div>
    </aside>

    <!-- Main Content Area -->
    <div class="flex-grow flex flex-col bg-surface overflow-hidden">
      <!-- Editor Tabs (Page Title) -->
      <div class="flex border-b border-border overflow-x-auto bg-surface shrink-0 no-scrollbar h-10">
        <div class="px-6 py-2 border-r border-border text-text text-sm flex items-center gap-4 bg-surface-elevated min-w-fit border-t-2 border-t-primary">
          <i class="fa-solid fa-code text-secondary text-xs"></i>
          <span class="font-mono">{t.projects.title}.json</span>
          <i class="fa-solid fa-xmark text-text-muted hover:text-text cursor-pointer text-xs"></i>
        </div>
      </div>

      <!-- Projects Grid -->
      <div class="flex-grow overflow-y-auto p-6 md:p-12 custom-scrollbar">
        {fetchError ? (
          <div class="h-full flex items-center justify-center text-text-muted font-mono">
            <p>// {t.projects.fetchError}</p>
          </div>
        ) : (
          <div class="grid grid-cols-1 lg:grid-cols-2 xl:grid-cols-3 gap-12 max-w-7xl mx-auto">
            {repos.map((repo, index) => {
              const repoTechs = [...(repo.languages || []), ...(repo.topics || [])].map(t => t.toLowerCase());
              return (
                <article class="project-card space-y-4 animate-in fade-in slide-in-from-bottom-4 duration-500 group" 
                         style={`animation-delay: ${index * 50}ms`}
                         data-techs={repoTechs.join(',')}>
                      <div class="flex items-center gap-2 mb-2 font-mono">
                        <span class="text-indigo font-bold text-sm">Project {index + 1}</span>
                        <span class="text-text-muted text-sm">// _{repo.name}</span>
                      </div>
                      <div class="bg-background/40 border border-border rounded-2xl overflow-hidden hover:border-text-muted transition-all flex flex-col h-full group-hover:shadow-2xl group-hover:shadow-secondary/5">
                        <div class="h-44 bg-surface-elevated/50 flex items-center justify-center relative overflow-hidden border-b border-border">
                          <i class={`${langIcons[repo.language || ""] || "fa-solid fa-code"} text-7xl text-border group-hover:scale-110 group-hover:text-text-muted/20 transition-all duration-700`}></i>
                          <div class="absolute inset-0 bg-gradient-to-t from-background/20 to-transparent"></div>
                        </div>
                        <div class="p-8 space-y-6 flex flex-col flex-grow">
                          <p class="text-text-muted text-[13px] leading-relaxed line-clamp-3 font-mono">
                            {repo.description || t.projects.noDescription}
                          </p>
                          <div class="mt-auto pt-4 flex gap-4">
                            <a href={repo.html_url} target="_blank" class="px-5 py-2.5 bg-surface-elevated border border-border text-text rounded-lg text-xs hover:bg-surface transition-colors font-mono hover:border-secondary">
                              view-project
                            </a>
                          </div>
                        </div>
                      </div>
                    </article>
                  )
                })}
          </div>
        )}
      </div>
    </div>
  </main>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const techFilters = document.querySelectorAll('.tech-filter') as NodeListOf<HTMLInputElement>;
      const projectCards = document.querySelectorAll('.project-card');
      const folderToggles = document.querySelectorAll('.folder-toggle');

      folderToggles.forEach(toggle => {
        toggle.addEventListener('click', () => {
          const targetId = toggle.getAttribute('data-target');
          if (!targetId) return;
          const target = document.getElementById(targetId);
          const icon = toggle.querySelector('i');
          if (target) {
            target.classList.toggle('hidden');
          }
          if (icon) {
            icon.classList.toggle('rotate-[-90deg]');
          }
        });
      });

      const filterProjects = () => {
        const activeTechs = Array.from(techFilters)
          .filter(f => f.checked)
          .map(f => f.value);

        projectCards.forEach(card => {
          const cardTechs = (card as HTMLElement).dataset.techs?.split(',') || [];
          const matches = activeTechs.length === 0 || activeTechs.some(tech => cardTechs.includes(tech));
          
          if (matches) {
            (card as HTMLElement).classList.remove('hidden');
          } else {
            (card as HTMLElement).classList.add('hidden');
          }
        });
      };

      techFilters.forEach(filter => {
        filter.addEventListener('change', (e) => {
          const checkbox = e.target as HTMLInputElement;
          const checkMark = checkbox.nextElementSibling?.querySelector('.check-mark');
          if (checkbox.checked) {
            checkMark?.classList.remove('hidden');
          } else {
            checkMark?.classList.add('hidden');
          }
          filterProjects();
        });

        if (filter.checked) {
          filter.nextElementSibling?.querySelector('.check-mark')?.classList.remove('hidden');
        }
      });
    });
  </script>
</Base>

<style>
  .project-card.hidden {
    display: none;
  }
</style>
