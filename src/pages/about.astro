---
import Base from "../layout/base.astro";
import { getTranslations, type Language } from "../i18n/utils"
import Bio from "../content/about/bio.md"
import BioEs from "../content/about/bio.es.md"
import Education from "../content/about/education.md"
import EducationEs from "../content/about/education.es.md"
import Experience from "../content/about/experience.md"
import ExperienceEs from "../content/about/experience.es.md"

const lang = (Astro.url.searchParams.get("lang") || "en") as Language;
const t = getTranslations(lang);

const skillIcons: Record<string, string> = {
  "Python": "devicon-python-plain",
  "Node.js": "devicon-nodejs-plain",
  "Java": "devicon-java-plain",
  "Go": "devicon-go-plain",
  "React": "devicon-react-original",
  "Angular": "devicon-angular-plain",
  "Vue": "devicon-vuejs-plain",
  "JavaScript": "devicon-javascript-plain",
  "HTML": "devicon-html5-plain",
  "Tailwind CSS": "devicon-tailwindcss-original",
  "PHP": "devicon-php-plain",
  "Laravel": "devicon-laravel-original",
  "SQL Server": "devicon-microsoftsqlserver-plain",
  "PostgreSQL": "devicon-postgresql-plain",
  "MySQL": "devicon-mysql-plain",
  "MongoDB": "devicon-mongodb-plain",
  "Git": "devicon-git-plain",
  "GitHub": "devicon-github-original",
  "Figma": "devicon-figma-plain",
  "Vercel": "devicon-vercel-original",
  "Supabase": "devicon-supabase-plain",
  "Cloudflare": "devicon-cloudflare-plain",
  "Azure": "devicon-azure-plain",
  "AWS": "devicon-amazonwebservices-plain-wordmark",
  "C#": "devicon-csharp-plain",
  "Kotlin": "devicon-kotlin-plain",
  ".NET": "devicon-dotnetcore-plain",
  "TypeScript": "devicon-typescript-plain",
};

---

<Base lang={lang} title="_about-me | Juan Manuel Machado" description="Advanced Software Engineering student with one year of professional Full-Stack experience in Python, JavaScript, React and Angular.">
  <link slot="head" rel="stylesheet" href="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/devicon.min.css" media="print" onload="this.media='all'" />
  <main class="flex-grow flex overflow-hidden h-full">
    <!-- Far Left Icon Strip -->
    <div class="w-12 border-r border-border flex flex-col items-center py-6 gap-8 bg-surface text-text-muted hidden md:flex shrink-0">
      <i class="fa-solid fa-files text-xl hover:text-text cursor-pointer transition-colors text-text"></i>
      <i class="fa-solid fa-circle-user text-xl hover:text-text cursor-pointer transition-colors"></i>
      <i class="fa-solid fa-code-merge text-xl hover:text-text cursor-pointer transition-colors"></i>
    </div>

    <!-- Left Sidebar (Explorer) -->
    <aside class="w-64 border-r border-border hidden md:flex flex-col bg-surface shrink-0">
      <div class="px-4 py-2 text-text-muted text-[11px] uppercase tracking-wider font-bold flex items-center justify-between border-b border-border">
        <span>explorer</span>
        <i class="fa-solid fa-ellipsis"></i>
      </div>
      
      <!-- Personal Info Section -->
      <div class="border-b border-border">
        <button class="folder-toggle w-full flex items-center gap-2 px-4 py-2 text-text text-sm hover:bg-surface-elevated transition-colors group font-mono" data-target="personal-info-files">
          <i class="fa-solid fa-caret-down text-[10px] transition-transform duration-200"></i>
          personal-info
        </button>
        <div class="pb-2 space-y-0.5" id="personal-info-files">
          <button data-file="bio" class="file-btn w-full flex items-center gap-2 px-8 py-1 text-text-muted text-sm hover:text-text hover:bg-surface-elevated transition-colors text-left">
            <i class="fa-solid fa-file-code text-rose text-xs"></i>
            bio.md
          </button>
          <button data-file="education" class="file-btn w-full flex items-center gap-2 px-8 py-1 text-text-muted text-sm hover:text-text hover:bg-surface-elevated transition-colors text-left">
            <i class="fa-solid fa-file-code text-indigo text-xs"></i>
            education.md
          </button>
          <button data-file="experience" class="file-btn w-full flex items-center gap-2 px-8 py-1 text-text-muted text-sm hover:text-text hover:bg-surface-elevated transition-colors text-left">
            <i class="fa-solid fa-file-code text-primary text-xs"></i>
            experience.md
          </button>
          <button data-file="skills" class="file-btn w-full flex items-center gap-2 px-8 py-1 text-text-muted text-sm hover:text-text hover:bg-surface-elevated transition-colors text-left">
            <i class="fa-solid fa-file-code text-accent text-xs"></i>
            skills.md
          </button>
        </div>
      </div>

        <!-- CV Download -->
        <div class="border-b border-border">
          <button class="folder-toggle w-full flex items-center gap-2 px-4 py-2 text-text text-sm hover:bg-surface-elevated transition-colors group font-mono" data-target="cv-files">
            <i class="fa-solid fa-caret-down text-[10px] transition-transform duration-200"></i>
            downloads
          </button>
          <div class="pb-2 space-y-0.5 hidden" id="cv-files">
            <a href="/docs/cv-juan-manuel-machado.pdf" download class="w-full flex items-center gap-2 px-8 py-1 text-text-muted text-[13px] hover:text-text transition-colors">
              <i class="fa-solid fa-file-pdf text-rose text-xs"></i>
              cv-en.pdf
            </a>
            <a href="/docs/cv-juan-manuel-machado-es.pdf" download class="w-full flex items-center gap-2 px-8 py-1 text-text-muted text-[13px] hover:text-text transition-colors">
              <i class="fa-solid fa-file-pdf text-rose text-xs"></i>
              cv-es.pdf
            </a>
          </div>
        </div>

        <!-- Contacts Section -->
      <div>
        <button class="folder-toggle w-full flex items-center gap-2 px-4 py-2 text-text text-sm hover:bg-surface-elevated transition-colors group font-mono" data-target="contacts-files">
          <i class="fa-solid fa-caret-down text-[10px] transition-transform duration-200"></i>
          contacts
        </button>
        <div class="pb-2 space-y-0.5" id="contacts-files">
          <a href="mailto:jmachadoact@gmail.com" class="w-full flex items-center gap-2 px-8 py-1 text-text-muted text-[13px] hover:text-text transition-colors">
            <i class="fa-solid fa-envelope text-xs"></i>
            email
          </a>
          <p class="w-full flex items-center gap-2 px-8 py-1 text-text-muted text-[13px]">
            <i class="fa-solid fa-phone text-xs"></i>
            +57 322 619 1781
          </p>
        </div>
      </div>
    </aside>

    <!-- Main Editor Area -->
    <div class="flex-grow flex flex-col bg-surface overflow-hidden">
      <!-- Editor Tabs -->
      <div class="flex border-b border-border overflow-x-auto bg-surface shrink-0 no-scrollbar h-10">
        <div id="active-tab" class="px-6 py-2 border-r border-border text-text text-sm flex items-center gap-4 bg-surface-elevated min-w-fit border-t-2 border-t-primary">
          <i class="fa-solid fa-file-code text-rose text-xs"></i>
          <span id="tab-name" class="font-mono">bio.md</span>
          <i class="fa-solid fa-xmark text-text-muted hover:text-text cursor-pointer text-xs"></i>
        </div>
      </div>

      <!-- Content -->
      <div class="flex-grow flex flex-col lg:flex-row overflow-hidden h-full">
        <!-- Text Content - Full Width -->
        <div class="flex-grow p-4 md:p-8 overflow-y-auto custom-scrollbar">
          <div class="flex gap-8">
            <div id="line-numbers" class="text-text-muted text-right select-none hidden sm:flex flex-col min-w-[2.5rem] font-mono text-sm pt-1 leading-[1.6rem] gap-0"></div>
            <div class="text-text-muted space-y-1 w-full font-mono text-sm pt-1">
              <div id="editor-content" class="text-text-muted space-y-4  border-l border-border/20">
                <div data-content="bio" class="content-section prose prose-invert max-w-none">
                  {lang === "es" ? <BioEs /> : <Bio />}
                </div>
                <div data-content="education" class="content-section hidden prose prose-invert max-w-none">
                  {lang === "es" ? <EducationEs /> : <Education />}
                </div>
                <div data-content="experience" class="content-section hidden prose prose-invert max-w-none">
                  {lang === "es" ? <ExperienceEs /> : <Experience />}
                </div>
                <div data-content="skills" class="content-section hidden">
                  <table class="w-full text-sm font-mono">
                    <thead>
                      <tr class="border-b border-border">
                        <th class="text-left py-2 pr-4 text-text-muted">Category</th>
                        <th class="text-left py-2 text-text-muted">Technologies</th>
                      </tr>
                    </thead>
                    <tbody class="text-text-muted">
                      {Object.entries(t.skill.categories).map(([key, cat]) => (
                        <tr class="border-b border-border/50">
                          <td class="py-3 pr-4 align-top">
                            <span class="text-secondary font-semibold">{cat.title}</span>
                          </td>
                          <td class="py-3 align-top">
                            <div class="flex flex-wrap gap-2">
                              {cat.technologies.map((tech) => (
                                <span class="inline-flex items-center gap-1.5 bg-surface-elevated px-2 py-1 rounded text-xs">
                                  <i class={`${skillIcons[tech] || "fa-solid fa-code"} text-xs text-text-muted`}></i>
                                  {tech}
                                </span>
                              ))}
                            </div>
                          </td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
</Base>

<style>
  .content-section :global(h1), 
  .content-section :global(h2), 
  .content-section :global(h3) {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 1rem;
    margin-top: 2rem;
    color: var(--color-text);
  }
  .content-section :global(p) {
    margin-bottom: 1rem;
    color: var(--color-text-muted);
  }
  .content-section :global(ul) {
    list-style-type: disc;
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }
  .content-section :global(li) {
    margin-bottom: 0.5rem;
    color: var(--color-text-muted);
    list-style: none;
  }
  .content-section :global(li)::before {
    content: "•  ";
    color: var(--color-text-muted);
  }
  .content-section :global(strong) {
    color: var(--color-secondary);
    font-weight: 600;
  }
  
  .file-btn.active {
    background-color: var(--color-surface-elevated);
    color: var(--color-text);
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const fileBtns = document.querySelectorAll('.file-btn');
    const contentSections = document.querySelectorAll('.content-section');
    const tabName = document.getElementById('tab-name');
    const folderToggles = document.querySelectorAll('.folder-toggle');

    // Set initial active state
    const firstBtn = document.querySelector('.file-btn[data-file="bio"]');
    if (firstBtn) firstBtn.classList.add('active');

    folderToggles.forEach(toggle => {
      toggle.addEventListener('click', () => {
        const targetId = toggle.getAttribute('data-target');
        if (!targetId) return;
        const target = document.getElementById(targetId);
        const icon = toggle.querySelector('i');
        if (target) {
          target.classList.toggle('hidden');
        }
        if (icon) {
          icon.classList.toggle('rotate-[-90deg]');
        }
      });
    });

    fileBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const file = btn.getAttribute('data-file');

        // Update active button
        fileBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');

        // Update tab name
        if (tabName) tabName.textContent = file + '.md';

        // Switch content
        let activeSection: HTMLElement | null = null;
        contentSections.forEach(section => {
          if (section.getAttribute('data-content') === file) {
            section.classList.remove('hidden');
            activeSection = section as HTMLElement;
          } else {
            section.classList.add('hidden');
          }
        });

        // Update line numbers after content renders
        if (activeSection) {
          requestAnimationFrame(() => updateLineNumbers(activeSection));
        }
      });
    });

    // Update line numbers based on visible content height
    const lineNumbersEl = document.getElementById('line-numbers');
    const updateLineNumbers = (section: HTMLElement | null) => {
      if (!lineNumbersEl || !section) return;
      const contentHeight = section.scrollHeight;
      const lineHeight = 22; // approx px for text-sm + prose spacing
      const lineCount = Math.max(1, Math.ceil(contentHeight / lineHeight)) + 2;
      lineNumbersEl.innerHTML = Array.from({ length: lineCount })
        .map((_, i) => `<span class="block leading-[1.6rem] h-[1.6rem]">${i + 2}</span>`)
        .join('');
    };

    // Set initial line numbers for bio on first load
    const bioSection = document.querySelector('[data-content="bio"]') as HTMLElement | null;
    if (bioSection) updateLineNumbers(bioSection);
  });
</script>
