---
import Base from "../layout/base.astro"
import { getTranslations, type Language } from '../i18n/utils'
import SnakeGame from "../components/SnakeGame.astro"

const lang = (Astro.url.searchParams.get('lang') || 'en') as Language;
const t = getTranslations(lang)
---

<Base lang={lang}>
  <main class="flex-grow flex flex-col xl:flex-row items-center justify-center p-6 md:p-12 gap-12 xl:gap-24 overflow-hidden relative min-h-full">
    <!-- Hero Content -->
    <div class="flex flex-col gap-10 z-10 w-full xl:w-auto max-w-2xl text-left">
      <div class="space-y-4">
        <p class="text-text font-medium text-lg tracking-tight">Hi all. I am</p>
        <h1 class="text-text text-5xl md:text-7xl font-light tracking-tighter leading-tight">Juan Manuel Machado</h1>
        <h2 class="text-secondary text-2xl md:text-4xl font-medium tracking-tight flex items-center gap-2">
          <span class="text-secondary">&gt;</span> {t.home.title}
        </h2>
      </div>

      <div class="space-y-4 text-text-muted text-sm md:text-base font-mono mt-8">
        <p>// {lang === 'en' ? 'complete the game to continue' : 'completa el juego para continuar'}</p>
        <p>// {lang === 'en' ? 'you can also see it on my Github page' : 'también puedes verlo en mi página de Github'}</p>
        <p>
          <span class="text-indigo">const</span> <span class="text-secondary">githubLink</span> = <a href="https://github.com/juan1417" target="_blank" class="text-rose hover:underline transition-all">"https://github.com/juan1417"</a>
        </p>
      </div>
    </div>

    <!-- Functional Snake Game -->
    <div class="z-10 w-full xl:w-auto xl:max-w-none max-w-2xl flex justify-center">
      <SnakeGame lang={lang} />
    </div>
  </main>
</Base>
